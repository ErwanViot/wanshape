# Supabase — required for auth features (optional: app works without)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Feature flags
VITE_FEATURE_CUSTOM_SESSION=false

# Push notifications — keep "false" until both google-services.json (Android)
# and GoogleService-Info.plist (iOS) are dropped into the native projects and
# Firebase has been provisioned. Setting it true without those files makes
# PushNotifications.register() throw a fatal Java/Obj-C exception that kills
# the app process the moment the user signs in.
VITE_PUSH_ENABLED=false

# Stripe price IDs
VITE_STRIPE_PRICE_MONTHLY=price_xxx
VITE_STRIPE_PRICE_YEARLY=price_xxx

# Sentry — error monitoring (optional: app works without)
VITE_SENTRY_DSN=https://xxx@xxx.ingest.de.sentry.io/xxx
# SENTRY_AUTH_TOKEN — sourcemap upload (build-time only, set in CI/Vercel, DO NOT commit)

# PostHog — product analytics (optional: empty key disables analytics entirely)
# Public key, exposed in the JS bundle by design. Get it from
# https://eu.posthog.com/project/settings → Project API key.
VITE_POSTHOG_KEY=phc_xxx
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Resend — transactional emails (set in Supabase Edge Functions secrets)
# RESEND_API_KEY=re_xxx
